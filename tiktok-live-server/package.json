{
  "name": "tiktok-live-server",
  "version": "1.0.0",
  "description": "TikTok 直播评论采集服务",
  "main": "server.js",
  "bin": "server.js",
  "scripts": {
    "test": "vitest run",
    "build:mac": "pkg . --target node18-macos-x64 --output dist/mac/tiktok-live-server",
    "build:win": "pkg . --target node18-win-x64 --output dist/win/tiktok-live-server.exe",
    "build:all": "npm run build:mac && npm run build:win"
  },
  "pkg": {
    "assets": [
      "utils.js"
    ],
    "outputPath": "dist"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "axios": "^1.13.4",
    "tiktok-live-connector": "^2.1.1-beta1",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@yao-pkg/pkg": "^6.3.0",
    "vitest": "^4.1.0"
  }
}
